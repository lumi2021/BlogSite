{
	"use-system-tmp": false,
	"page-host-url": "http://localhost:5148/",

	"global-variables": {
		"toolName" : "BlogSite",
		"ifTest": true,
		"forTest": ["foo", "bar", "baz"]
	},
	
	"routes": [
		{
			"path": "/",
			"source": "./global",
			
			"subroutes": [
				{ "stat":  404, "source": "./pages/error-404" },
				{ "path": "/", "source": "./pages/main" },

				{
					"path":  "/blog",
					"source": "./pages/blog/container",
					"subroutes": [
						{ "path": "/", "source": "./pages/blog/index" },
						{ "auto": "./blog", "id": "blogs_index" }
					]
				},

				{
					"path":  "/docs",
					"source": "./pages/docs/index",
					"subroutes": [
						{ "auto": "./docs", "mode": "tree", "id": "docs_index" }
					]
				}
			]
		}
	],
	"components": "./components"
}
